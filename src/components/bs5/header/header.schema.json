{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "",
  "type": "object",
  "properties": {
    "icon-root": {
      "type": "string",
      "minLength": 1
    },
    "icons": {
      "type": "object",
      "properties": {
        "menu-icon": {
          "type": "string",
          "minLength": 1
        },
        "search-icon": {
          "type": "string",
          "minLength": 1
        },
        "close-icon": {
          "type": "string",
          "minLength": 1
        },
        "chevron_down": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["menu-icon", "search-icon", "close-icon", "chevron_down"]
    },
    "sitePreHeader": {
      "type": "object",
      "properties": {
        "url": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["value"]
        },
        "text": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["value"]
        },
        "CTA": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 1,
          "items": {
            "required": ["id", "dropdown_enabled"],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "url": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["value"]
              },
              "text": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": ["value"]
              },
              "dropdown_enabled": {
                "type": "boolean"
              },
              "dropdown_options": {
                "type": "object",
                "properties": {
                  "dropdown_type": {
                    "type": "string",
                    "minLength": 1
                  },
                  "view_more": {
                    "type": "boolean"
                  },
                  "label": {
                    "type": "string",
                    "minLength": 1
                  },
                  "url": {
                    "type": "string",
                    "minLength": 1
                  },
                  "target": {
                    "type": "string",
                    "minLength": 1
                  },
                  "dropdown_config": {
                    "type": "object",
                    "properties": {
                      "groups": {
                        "type": "array",
                        "uniqueItems": true,
                        "minItems": 1,
                        "items": {
                          "required": ["action", "url", "label"],
                          "properties": {
                            "action": {
                              "type": "string",
                              "minLength": 1
                            },
                            "url": {
                              "type": "string",
                              "minLength": 1
                            },
                            "label": {
                              "type": "string",
                              "minLength": 1
                            }
                          }
                        }
                      }
                    },
                    "required": ["groups"]
                  }
                },
                "required": [
                  "dropdown_type",
                  "view_more",
                  "label",
                  "url",
                  "target",
                  "dropdown_config"
                ]
              }
            }
          }
        }
      },
      "required": ["url", "text", "CTA"]
    },
    "siteHeader": {
      "type": "object",
      "properties": {
        "config": {
          "type": "object",
          "properties": {
            "masterbrand_enabled": {
              "type": "boolean"
            },
            "subbrand_enabled": {
              "type": "boolean"
            },
            "cobrand_enabled": {
              "type": "boolean"
            },
            "endorsed_enabled": {
              "type": "boolean"
            },
            "standalone_enabled": {
              "type": "boolean"
            }
          },
          "required": [
            "masterbrand_enabled",
            "subbrand_enabled",
            "cobrand_enabled",
            "endorsed_enabled",
            "standalone_enabled"
          ]
        },
        "url": {
          "type": "object",
          "properties": {
            "value": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["value"]
        },
        "secondaryType": {
          "type": "object",
          "properties": {
            "logo": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                }
              },
              "required": ["value"]
            },
            "siteTitle": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                }
              },
              "required": ["value"]
            },
            "subline": {
              "type": "object",
              "properties": {
                "value": {
                  "type": "string"
                }
              },
              "required": ["value"]
            }
          },
          "required": ["logo", "siteTitle", "subline"]
        }
      },
      "required": ["config", "url", "secondaryType"]
    },
    "siteSearchAsset": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "placeholder": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "formAction": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": ["url"]
        },
        "options": {
          "type": "object",
          "properties": {
            "borderStyle": {
              "type": "object",
              "properties": {
                "full": {
                  "type": "boolean"
                }
              },
              "required": ["full"]
            }
          },
          "required": ["borderStyle"]
        }
      },
      "required": ["value", "placeholder", "label", "formAction", "options"]
    }
  },
  "required": [
    "icon-root",
    "icons",
    "sitePreHeader",
    "siteHeader",
    "siteSearchAsset"
  ]
}
