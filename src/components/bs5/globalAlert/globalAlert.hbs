<!-- QGDS Component: Global Alert -->

<div class="global-alert-include">
  {{#each alertItems}}
  <section class="global-alert alert d-none {{variant}}" data-variant="{{variant}}"{{#if id}} data-id="{{id}}"{{/if}}{{#if expiryDays}} data-expiry-days="{{expiryDays}}"{{/if}}>
      <div class="qld-global-alert-main container-full">
        <div class="global-alert-icon">
            {{#ifCond variant '==' 'global-alert-critical'}}
              {{> icon size="sm" ariaLabel="Critical alert" iconId="alert-danger"}}
            {{else ifCond variant '==' 'global-alert-info'}}
              {{> icon size="sm" ariaLabel="Information alert" iconId="alert-information"}}
            {{else ifCond variant '==' 'global-alert-warning'}}
              {{> icon size="sm" ariaLabel="Warning alert" iconId="alert-warning"}}
            {{/ifCond}}
        </div>

        <div class="global-alert-content">
          <div class="global-alert-message">
            {{{content}}}
          </div>
          <div class="global-alert-action">
            {{{action}}}
          </div>
        </div>
        <div class="global-alert-close">
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
      </div>
  </section>
  {{/each }}
</div>
