<!-- QGDS Component: Tag -->

<ul class="tag-list {{variant}}">
  {{#each tagItems}}
    <li class="tag-item {{classes}} {{../size}} {{../emphasis}}">
      {{{content}}}
      {{#if applied-filter}}
        <button class="tag-clear-filter-button">
          <span class="tag-clear-filter-button-icon-wrapper">
            <svg aria-label="Remove" class="tag-clear-filter-button-icon">
              <use href="./assets/img/icons-sprite.svg#qgds-icon-close" />
            </svg>
          </span>
        </button>
      {{/if}}
    </li>
  {{/each }}
</ul>
